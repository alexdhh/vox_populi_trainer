                                        <Ellipse Fill="#8B3DFF" WidthRequest="8" HeightRequest="8" HorizontalOptions="Center" VerticalOptions="Center" IsVisible="False">
                                            <Ellipse.Triggers>
                                                <DataTrigger TargetType="Ellipse" Binding="{Binding SelectedTimeOption}" Value="4h">
                                                    <Setter Property="IsVisible" Value="True" />

                        <Border StrokeShape="RoundRectangle 12" Stroke="#E5E7EB" StrokeThickness="1.5" BackgroundColor="White">
                            <Border.Triggers>
                                <DataTrigger TargetType="Border" Binding="{Binding SelectedTimeOption}" Value="4h">
                                    <Setter Property="Stroke" Value="#A855F7" />
                                    <Setter Property="BackgroundColor" Value="#FBF5FF" />
                                    <Setter Property="Shadow">
                                        <Setter.Value>
                                            <Shadow Brush="#A855F7" Opacity="0.25" Radius="15" Offset="0,4" />
                                        </Setter.Value>
                                    </Setter>
                                </DataTrigger>

                                                <Ellipse.Triggers>
                                                    <DataTrigger TargetType="Ellipse" Binding="{Binding SelectedTimeOption}" Value="custom">
                                                        <Setter Property="IsVisible" Value="True" />
                                                    </DataTrigger>
                                                </Ellipse.Triggers>
                                            </Ellipse>
                                        </Border>
                                        <Label Text="Durée personnalisée" FontSize="15" VerticalOptions="Center">
                                            <Label.Triggers>
                                                <DataTrigger TargetType="Label" Binding="{Binding SelectedTimeOption}" Value="custom">
                                                    <Setter Property="TextColor" Value="#8B3DFF" />
                                                    <Setter Property="FontAttributes" Value="Bold" />
                                                </DataTrigger>
                                            </Label.Triggers>
                                        </Label>
                                    </HorizontalStackLayout>
                                </VerticalStackLayout>

                                <HorizontalStackLayout HorizontalOptions="Start" Margin="50,55,0,20" Spacing="10" InputTransparent="False">
                                    <Grid>
                                        <Entry x:Name="CustomTimeEntry" 
                                               Placeholder="Entrez le temps" 
                                               Text="{Binding CustomTimeInput}" 
                                               Keyboard="Numeric" 
                                               WidthRequest="200" 
                                               BackgroundColor="White"
                                               IsEnabled="False">
                                            <Entry.Triggers>
                                                <DataTrigger TargetType="Entry" Binding="{Binding SelectedTimeOption}" Value="custom">
                                                    <Setter Property="IsEnabled" Value="True" />
                                                </DataTrigger>
                                            </Entry.Triggers>
                                        </Entry>

                                        <BoxView BackgroundColor="Transparent">
                                            <BoxView.Triggers>
                                                <DataTrigger TargetType="BoxView" Binding="{Binding SelectedTimeOption}" Value="custom">
                                                    <Setter Property="IsVisible" Value="False" />
                                                </DataTrigger>
                                            </BoxView.Triggers>
                                            <BoxView.GestureRecognizers>
                                                <TapGestureRecognizer Command="{Binding SelectTimeCommand}" CommandParameter="custom" />
                                            </BoxView.GestureRecognizers>
                                        </BoxView>
                                    </Grid>
                                    <Label Text="secondes" VerticalOptions="Center" TextColor="#6B7280" />
                                </HorizontalStackLayout>
                            </Grid>
                        </Border>

                    </VerticalStackLayout>

                    <Button Text="Commencer l'entraînement"
                            Command="{Binding StartTrainingCommand}"
                            Background="{StaticResource PrimaryGradient}"
                            TextColor="White"
                            CornerRadius="12"
                            FontAttributes="Bold"
                            WidthRequest="300"
                            HeightRequest="55"
                            FontSize="16"
                            Margin="0,30,0,0"
                            HorizontalOptions="Center" />

                </VerticalStackLayout>
            </VerticalStackLayout>
        </Grid>
    </ScrollView>

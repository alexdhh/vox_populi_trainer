                                        </Ellipse>
                                    </Border>
                                    <Label Text="4 heures" FontSize="15" VerticalOptions="Center">
                                        <Label.Triggers>
                                            <DataTrigger TargetType="Label" Binding="{Binding SelectedTimeOption}" Value="4h">
                                                <Setter Property="TextColor" Value="#8B3DFF" />
                                                <Setter Property="FontAttributes" Value="Bold" />
                                            </DataTrigger>
                                        </Label.Triggers>

                                    <Setter Property="BackgroundColor" Value="#FBF5FF" />
                                    <Setter Property="Shadow">
                                        <Setter.Value>
                                            <Shadow Brush="#A855F7" Opacity="0.25" Radius="15" Offset="0,4" />
                                        </Setter.Value>
                                    </Setter>
                                </DataTrigger>
                            </Border.Triggers>
                            <Grid>
                                <HorizontalStackLayout Spacing="15" InputTransparent="True" Padding="20">
                                    <Border HeightRequest="16" WidthRequest="16" StrokeShape="RoundRectangle 8" Stroke="#D1D5DB" StrokeThickness="2" BackgroundColor="White" VerticalOptions="Center">
                                        <Border.Triggers>
                                            <DataTrigger TargetType="Border" Binding="{Binding SelectedTimeOption}" Value="1h">
                                                <Setter Property="Stroke" Value="#8B3DFF" />
                                            </DataTrigger>
                                        </Border.Triggers>
                                        <Ellipse Fill="#8B3DFF" WidthRequest="8" HeightRequest="8" HorizontalOptions="Center" VerticalOptions="Center" IsVisible="False">
                                            <Ellipse.Triggers>
                                                <DataTrigger TargetType="Ellipse" Binding="{Binding SelectedTimeOption}" Value="1h">
                                                    <Setter Property="IsVisible" Value="True" />
                                                </DataTrigger>
                                            </Ellipse.Triggers>
                                        </Ellipse>
                                    </Border>
                                    <Label Text="1 heure" FontSize="15" VerticalOptions="Center">
                                        <Label.Triggers>
                                            <DataTrigger TargetType="Label" Binding="{Binding SelectedTimeOption}" Value="1h">
                                                <Setter Property="TextColor" Value="#8B3DFF" />
                                                <Setter Property="FontAttributes" Value="Bold" />
                                            </DataTrigger>
                                        </Label.Triggers>
                                    </Label>
                                </HorizontalStackLayout>
                                <BoxView BackgroundColor="Transparent">
                                    <BoxView.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding SelectTimeCommand}" CommandParameter="1h" />
                                        <PointerGestureRecognizer PointerEntered="OnModelPointerEntered" PointerExited="OnModelPointerExited" />
                                    </BoxView.GestureRecognizers>
                                </BoxView>
                            </Grid>
                        </Border>

                        <Border StrokeShape="RoundRectangle 12" Stroke="#E5E7EB" StrokeThickness="1.5" BackgroundColor="White">
                            <Border.Triggers>
                                <DataTrigger TargetType="Border" Binding="{Binding SelectedTimeOption}" Value="2h">
                                    <Setter Property="Stroke" Value="#A855F7" />
                                    <Setter Property="BackgroundColor" Value="#FBF5FF" />
                                    <Setter Property="Shadow">
                                        <Setter.Value>
                                            <Shadow Brush="#A855F7" Opacity="0.25" Radius="15" Offset="0,4" />
                                        </Setter.Value>
                                    </Setter>
                                </DataTrigger>
                            </Border.Triggers>
                            <Grid>
                                <HorizontalStackLayout Spacing="15" InputTransparent="True" Padding="20">
                                    <Border HeightRequest="16" WidthRequest="16" StrokeShape="RoundRectangle 8" Stroke="#D1D5DB" StrokeThickness="2" BackgroundColor="White" VerticalOptions="Center">
                                        <Border.Triggers>
                                            <DataTrigger TargetType="Border" Binding="{Binding SelectedTimeOption}" Value="2h">
                                                <Setter Property="Stroke" Value="#8B3DFF" />
                                            </DataTrigger>
                                        </Border.Triggers>
                                        <Ellipse Fill="#8B3DFF" WidthRequest="8" HeightRequest="8" HorizontalOptions="Center" VerticalOptions="Center" IsVisible="False">
                                            <Ellipse.Triggers>
                                                <DataTrigger TargetType="Ellipse" Binding="{Binding SelectedTimeOption}" Value="2h">
                                                    <Setter Property="IsVisible" Value="True" />
                                                </DataTrigger>
                                            </Ellipse.Triggers>
                                        </Ellipse>
                                    </Border>
                                    <Label Text="2 heures" FontSize="15" VerticalOptions="Center">
                                        <Label.Triggers>
                                            <DataTrigger TargetType="Label" Binding="{Binding SelectedTimeOption}" Value="2h">
                                                <Setter Property="TextColor" Value="#8B3DFF" />
                                                <Setter Property="FontAttributes" Value="Bold" />
                                            </DataTrigger>
                                        </Label.Triggers>
                                    </Label>
                                </HorizontalStackLayout>
                                <BoxView BackgroundColor="Transparent">
                                    <BoxView.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding SelectTimeCommand}" CommandParameter="2h" />
                                        <PointerGestureRecognizer PointerEntered="OnModelPointerEntered" PointerExited="OnModelPointerExited" />
                                    </BoxView.GestureRecognizers>
                                </BoxView>
                            </Grid>

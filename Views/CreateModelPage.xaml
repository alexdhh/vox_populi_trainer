                                        <PointerGestureRecognizer PointerEntered="OnModelPointerEntered" PointerExited="OnModelPointerExited" />
                                    </BoxView.GestureRecognizers>
                                </BoxView>

                                <VerticalStackLayout InputTransparent="True" Padding="20" Spacing="15">
                                    <HorizontalStackLayout Spacing="15">
                                        <Border HeightRequest="16" WidthRequest="16" StrokeShape="RoundRectangle 8" Stroke="#D1D5DB" StrokeThickness="2" BackgroundColor="White" VerticalOptions="Center">
